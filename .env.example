# ─────────────────────────────────────────────────────────────────────────────
# Bakup Developer Preview — Environment Configuration
#
# Copy this file to .env and fill in the required values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────


# ── Required ─────────────────────────────────────────────────────────────────

# Developer Preview access key.
# For this build the key is: tango
# Set it exactly as shown — case-sensitive, no quotes, no trailing whitespace.
# The application will not start if this is missing or incorrect.
BAKUP_ACCESS_KEY=tango

# (Optional) Absolute path to a local project directory for indexing.
# Leave blank if you prefer to upload files through the browser UI.
# Example: /home/you/projects/my-service
# BAKUP_PROJECT_PATH=


# ── Server ────────────────────────────────────────────────────────────────────

# Host to bind the backend API server.
# Do not change to 0.0.0.0 — this tool is not designed to be network-exposed.
BAKUP_HOST=127.0.0.1

# Port for the backend API.
BAKUP_PORT=8000

# Log verbosity: debug | info | warning | error
BAKUP_LOG_LEVEL=info


# ── Storage ───────────────────────────────────────────────────────────────────

# Directory where ChromaDB will persist the vector index.
# Relative to the backend working directory, or use an absolute path.
BAKUP_CHROMA_DIR=vectordb

# Name of the ChromaDB collection. Only change if running multiple projects.
BAKUP_CHROMA_COLLECTION=bakup

# Directory where model weights are cached after first download.
BAKUP_MODEL_CACHE_DIR=model-weights


# ── Models ────────────────────────────────────────────────────────────────────

# Sentence-transformers model used for embeddings.
# Must be a model available locally or downloadable from Hugging Face.
# Default is a well-balanced 80MB model.
BAKUP_EMBEDDING_MODEL=all-MiniLM-L6-v2

# GGUF model filename inside BAKUP_MODEL_CACHE_DIR.
# Run scripts/download-models.sh to pull the default model.
BAKUP_LLM_MODEL_FILE=llama-3.2-3b-instruct.Q4_K_M.gguf


# ── Inference ─────────────────────────────────────────────────────────────────

# Context window size passed to llama.cpp. Reduce if you encounter OOM errors.
BAKUP_LLM_CONTEXT_WINDOW=4096

# Maximum tokens in a generated response.
BAKUP_LLM_MAX_TOKENS=512

# LLM temperature. Keep low for factual, citation-backed answers.
BAKUP_LLM_TEMPERATURE=0.1


# ── Retrieval ─────────────────────────────────────────────────────────────────

# Number of chunks retrieved from the vector store per query.
BAKUP_RETRIEVAL_TOP_K=8

# Chunks with a similarity score below this threshold are returned but
# flagged as low-confidence in the response.
BAKUP_CONFIDENCE_THRESHOLD=0.35
