# bakup.ai backend — Docker build context exclusions
# Keeps the image build fast and the image small.

__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/

# Local data — never bake into the image
vectordb/
model-weights/
downloads/
projects/
logs/

# Git / IDE
.git/
.gitignore
.vscode/
.idea/

# Env files
.env
.env.*
!.env.example

# Tests
test_*.py
tests/

# Docs (not needed at runtime)
*.md
LICENSE
